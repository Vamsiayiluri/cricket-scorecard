rules_version = '2';

/**
 * Phase D rules — backward-compatible with existing matches.
 * Missing user profile is treated as scorer (legacy accounts).
 * Review in Firebase Console before deploy.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userProfileExists() {
      return exists(userDocPath());
    }

    function userRole() {
      return userProfileExists() ? get(userDocPath()).data.role : 'viewer';
    }

    function isScorer() {
      return isSignedIn() && userRole() in ['scorer', 'admin'];
    }

    function isAdmin() {
      return isSignedIn() && userRole() in ['scorer', 'admin'];
    }

    function isPublicMatch() {
      return resource.data.isPublic == true;
    }

    function isPublicTournamentMatch() {
      let tournamentId = resource.data.tournamentId;
      return tournamentId is string
        && get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.isPublic == true;
    }

    function isMatchOwner() {
      return isSignedIn()
        && resource.data.get('createdBy', request.auth.uid) == request.auth.uid;
    }

    function isMatchCollaborator() {
      return isSignedIn()
        && request.auth.uid in resource.data.get('collaboratorUids', []);
    }

    function isMatchManager() {
      return isMatchOwner() || isAdmin();
    }

    function hasSameMatchManagementFields() {
      return request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('collaboratorUids', []) == resource.data.get('collaboratorUids', [])
        && request.resource.data.get('isPublic', true) == resource.data.get('isPublic', true)
        && request.resource.data.get('archivedAt', null) == resource.data.get('archivedAt', null)
        && request.resource.data.get('deletedAt', null) == resource.data.get('deletedAt', null)
        && request.resource.data.matchDetails == resource.data.matchDetails
        && request.resource.data.teams == resource.data.teams
        && request.resource.data.tossDetails == resource.data.tossDetails
        && request.resource.data.scoringRules == resource.data.scoringRules;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Self-upgrade: viewer → scorer allowed; no other role changes permitted.
      allow update: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
        );
    }

    match /matches/{matchId} {
      // Public matches: anyone can read. Private matches: owner only.
      // Legacy docs without createdBy fall back to uid — preserves access for original scorer.
      allow read: if isPublicMatch()
        || isPublicTournamentMatch()
        || isMatchManager()
        || isMatchCollaborator();

      // Create: scorer/admin only; new doc must carry caller's uid as createdBy.
      allow create: if isScorer() && request.resource.data.createdBy == request.auth.uid;

      // Delete: owner only (or legacy docs without createdBy field).
      allow delete: if isScorer()
        && isMatchManager();

      // Update rules (owner-only):
      // - Scheduled: full edits allowed.
      // - In-progress: scoreCard writes allowed; structural fields (teams/toss/rules) locked.
      // - Completed: only metadata (notes, isPublic, playerOfTheMatch) may change.
      allow update: if isScorer()
        && (
          (
            isMatchManager()
            && (
              resource.data.status == 'scheduled'
              ||
              (resource.data.status == 'in-progress'
                && request.resource.data.teams == resource.data.teams
                && request.resource.data.tossDetails == resource.data.tossDetails
                && request.resource.data.scoringRules == resource.data.scoringRules
              )
              ||
              resource.data.status == 'completed'
            )
          )
          ||
          (
            isMatchCollaborator()
            && hasSameMatchManagementFields()
          )
        );
    }

    match /scorer_requests/{requestId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'resolvedAt', 'resolvedBy']);
      allow delete: if false;
    }

    match /match_access_requests/{requestId} {
      allow read: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.requestedBy == request.auth.uid
            || resource.data.matchOwnerUid == request.auth.uid
          )
        );
      allow create: if isScorer()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.matchId is string
        && request.resource.data.matchOwnerUid is string
        && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.createdBy
          == request.resource.data.matchOwnerUid;
      allow update: if isAdmin()
        || (
          isScorer()
          && resource.data.matchOwnerUid == request.auth.uid
          && request.resource.data.matchId == resource.data.matchId
          && request.resource.data.matchOwnerUid == resource.data.matchOwnerUid
          && request.resource.data.requestedBy == resource.data.requestedBy
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'resolvedAt', 'resolvedBy'])
        );
      allow delete: if false;
    }

    match /teams/{teamId} {
      // Scorers can only read/write their own teams.
      allow read: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if isScorer() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isScorer() && resource.data.createdBy == request.auth.uid;
      allow delete: if isScorer() && resource.data.createdBy == request.auth.uid;
    }

    match /players/{playerId} {
      // Scorers can only read/write their own player catalog entries.
      allow read: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if isScorer() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isScorer() && resource.data.createdBy == request.auth.uid;
      allow delete: if isScorer() && resource.data.createdBy == request.auth.uid;
    }

    // Follow mechanics: any authenticated user can follow/unfollow any match.
    // Any authenticated user can read the followers list (scorer needs this to fan-out notifications).
    match /matchFollowers/{matchId}/followers/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Tournaments: public reads; owner/admin management.
    match /tournaments/{tournamentId} {
      allow read: if resource.data.isPublic == true
        || (isSignedIn() && resource.data.organizerId == request.auth.uid)
        || isAdmin();
      allow create: if isScorer() && request.resource.data.organizerId == request.auth.uid;
      allow update: if isScorer()
        && (resource.data.organizerId == request.auth.uid || isAdmin());
      allow delete: if isScorer()
        && (resource.data.organizerId == request.auth.uid || isAdmin());

      // Fixtures subcollection: public tournament fixtures are readable by anyone;
      // only the tournament owner or an admin can create/edit/delete fixtures.
      match /fixtures/{fixtureId} {
        allow read: if get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.isPublic == true
          || (
            isSignedIn()
            && get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.organizerId == request.auth.uid
          )
          || isAdmin();
        allow create, update, delete: if isScorer()
          && (
            get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.organizerId == request.auth.uid
            || isAdmin()
          );
      }
    }

    // AuctionArena import records: importers can read/write their own.
    match /imports/{importId} {
      allow read: if isScorer() && resource.data.importedBy == request.auth.uid;
      allow create: if isScorer() && request.resource.data.importedBy == request.auth.uid;
      allow update: if isScorer() && resource.data.importedBy == request.auth.uid;
      allow delete: if isScorer() && resource.data.importedBy == request.auth.uid;
    }

    // In-app notifications: recipients read/update/delete their own.
    // Any authenticated user can create (scorer generates notifications for followers).
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId is string
        && request.resource.data.matchId is string
        && request.resource.data.type in ['match_started', 'match_completed', 'potm_announced'];
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
